# Configuração de ambiente — Fórum de Mulheres no Turismo
# Copie este arquivo para .env e preencha os valores antes do setup.
# NUNCA comite o arquivo .env no repositório.

# Senhas iniciais para o setup (mínimo 12 caracteres cada)
SETUP_ADMIN_PASSWORD=
SETUP_EDITOR_PASSWORD=

# SMTP (necessário para recuperação de senha por e-mail)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@turismo.gov.br
